[Unit]
Description=Fabric node data-plane agent
Documentation=https://fabric.mcnutt.cloud
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/fabric/agent.env
WorkingDirectory=/opt/fabric/node-agent
ExecStart=/usr/bin/python3 -m fabric_agent
Restart=always
RestartSec=5
# Data-plane programming (WireGuard, ip rules, iptables) needs privileges.
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE
NoNewPrivileges=false
StateDirectory=fabric
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
