# Fabric Management Layer — environment configuration
# Copy to .env and adjust. Values here are safe dev defaults.

# --- Core ---
FABRIC_ENV=dev
FABRIC_SECRET_KEY=change-me-in-production-please-32bytes-min
FABRIC_PUBLIC_URL=http://localhost:8080
FABRIC_DOMAIN=fabric.mcnutt.cloud

# --- Database ---
# dev default is SQLite; production example:
# FABRIC_DATABASE_URL=postgresql+psycopg://fabric:fabric@localhost:5432/fabric
FABRIC_DATABASE_URL=sqlite:///./fabric.db

# --- Realtime event bus ---
# in-process (single node) or redis://host:6379/0 for HA
FABRIC_EVENTBUS_URL=inproc

# --- McNutt Cloud auth integration ---
FABRIC_AUTH_LOGIN_BASE=https://login.mcnutt.cloud
FABRIC_AUTH_APP_ID=fabric-console
FABRIC_AUTH_APP_SECRET=replace_with_strong_shared_secret
FABRIC_AUTH_COOKIE_NAME=fabric_auth
FABRIC_AUTH_COOKIE_DOMAIN=.mcnutt.cloud
FABRIC_AUTH_TTL_SEC=7200
FABRIC_AUTH_REFRESH_SEC=1200
FABRIC_AUTH_ADMIN_ROLES=admin,fabric_admin

# --- PKI ---
# passphrase used to encrypt CA private keys at rest
FABRIC_PKI_PASSPHRASE=change-me-pki-passphrase
FABRIC_PKI_DIR=./pki_store

# --- Fabric addressing ---
FABRIC_NODE_CIDR=100.96.0.0/12
FABRIC_ENDPOINT_CIDR=100.64.0.0/12
FABRIC_WG_PORT=51820

# --- AWS Route53 (optional, for DNS automation) ---
FABRIC_ROUTE53_ZONE_ID=
AWS_REGION=us-east-1
